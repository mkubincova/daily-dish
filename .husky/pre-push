api_url="${NUXT_PUBLIC_API_URL:-http://localhost:8000}"

# Only check type drift when the generated file is committed-clean — otherwise the
# user is mid-iteration and knows what they're doing.
if git diff --quiet apps/web/types/api.d.ts && git diff --cached --quiet apps/web/types/api.d.ts; then
  if curl -s -o /dev/null --max-time 2 "$api_url/openapi.json"; then
    npm --prefix apps/web run codegen > /dev/null
    if ! git diff --quiet apps/web/types/api.d.ts; then
      echo "✘ apps/web/types/api.d.ts drifted after codegen."
      echo "  Commit the regenerated file, or run: npm --prefix apps/web run codegen"
      exit 1
    fi
  else
    echo "pre-push: $api_url unreachable — skipping type regen."
  fi
fi

npm run typecheck:web

# Run basedpyright only when Python files in apps/api have changed against origin.
# Falls back to running unconditionally if origin/main is missing (first push).
if git rev-parse --verify origin/main >/dev/null 2>&1; then
  if git diff --name-only origin/main...HEAD -- 'apps/api/**/*.py' | grep -q .; then
    (cd apps/api && uv run --quiet basedpyright)
  fi
else
  (cd apps/api && uv run --quiet basedpyright)
fi
