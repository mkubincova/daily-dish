# Database (asyncpg connection string)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/daily_dish

# Session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret

# Frontend URL for CORS and OAuth redirects
FRONTEND_URL=http://localhost:3000

# Environment: development | production
ENVIRONMENT=development

# GitHub OAuth app (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth client (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
