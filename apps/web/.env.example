# Backend origin for the Nuxt proxy (no trailing slash, no /api suffix — the proxy adds the prefix).
# In production, set this to the Railway URL. Locally, defaults to http://localhost:8000.
NUXT_API_PROXY_TARGET=http://localhost:8000

# OAuth client IDs (public — safe to include in frontend env)
# Set these to the client IDs from your OAuth apps
NUXT_PUBLIC_GITHUB_CLIENT_ID=
NUXT_PUBLIC_GOOGLE_CLIENT_ID=
