{
	"name": "web",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "npm run codegen && nuxt build",
		"dev": "nuxt dev",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "nuxi typecheck",
		"codegen": "openapi-typescript ${NUXT_API_PROXY_TARGET:-http://localhost:8000}/openapi.json -o ./types/api.d.ts",
		"test": "vitest run"
	},
	"dependencies": {
		"@nuxtjs/tailwindcss": "^6.14.0",
		"@phosphor-icons/vue": "^2.2.1",
		"@pinia/nuxt": "^0.11.3",
		"nuxt": "^4.4.2",
		"openapi-typescript": "^7.13.0",
		"pinia": "^3.0.4",
		"vue": "^3.5.32",
		"vue-router": "^5.0.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@nuxt/test-utils": "^4.0.2",
		"@types/node": "^25.6.0",
		"@vue/test-utils": "^2.4.8",
		"happy-dom": "^20.9.0",
		"vitest": "^4.1.5",
		"vue-tsc": "^3.2.7"
	}
}
